#!/bin/bash

M3SA_OPENDC_JAR="bin/M3SA.jar"
M3SA_PY="bin/m3sa"

# Figure 4A
FIGURE_4_SCENARIO1="figures/figure4/inputs/scenario1.json"
FIGURE_4_SETUP1="figures/figure4/inputs/m3saSetup1.json"

# Figure 4B
FIGURE_4_SCENARIO2="figures/figure4/inputs/scenario2.json"
FIGURE_4_SETUP2="figures/figure4/inputs/m3saSetup2.json"

# Figure 4C
FIGURE_4_SCENARIO3="figures/figure4/inputs/scenario3.json"
FIGURE_4_SETUP3="figures/figure4/inputs/m3saSetup3.json"

# Figure 6A
FIGURE_6_SCENARIO="figures/figure6/inputs/scenario.json"
FIGURE_6_SETUP1="figures/figure6/inputs/m3saSetup1.json"
FIGURE_6_SETUP20="figures/figure6/inputs/m3saSetup20.json"
FIGURE_6_SETUP100="figures/figure6/inputs/m3saSetup100.json"

# Paths to Experiment1 Footprinter -> Fig 9A
EXP1_FOOTPRINTER_RAW="experiments/experiment1/footprinter/raw-output"
EXP1_FOOTPRINTER_M3SA="experiments/experiment1/footprinter/m3saSetup.json"
EXP1_FOOTPRINTER_RESULT="results/experiment1/footprinter"
# Paths to Experiment1 MultiModel -> Fig 9B
EXP1_MULTIMODEL_SCENARIO="experiments/experiment1/multimodel/scenario.json"
EXP1_MULTIMODEL_M3SA="experiments/experiment1/multimodel/m3saSetup.json"
EXP1_MULTIMODEL_RESULT="results/experiment1/multimodel"
# Paths to Experiment1 MetaModel -> Fig 9C
EXP1_METAMODEL_SCENARIO="experiments/experiment1/metamodel/scenario.json"
EXP1_METAMODEL_M3SA="experiments/experiment1/metamodel/m3saSetup.json"
EXP1_METAMODEL_RESULT="results/experiment1/metamodel"

EXP2_FAILURE_MODELS=("-failures" "-nofailures")
EXP2_EXPERIMENTS=("marconi" "solvinity")
EXP2_SCENARIO_PATH="experiments/experiment2/scenarios"
EXP2_M3SA_SETUP="experiments/experiment2/inputs"

EXP3_SCENARIOS_PATH="experiments/experiment3/inputs/scenarios"
EXP3_M3SA_SETUP="experiments/experiment3/inputs/m3saSetup.json"
EXP3_SIMULATION_RESULTS_PATH="results/experiment3/"
EXP3_METAMODELS_PATH="results/experiment3/metamodels"
EXP3_PLOTTER_PATH="experiments/experiment3/scripts/main.py"
EXP3_METAMODELS_COLLECTION="experiments/experiment3/metamodels"

main() {
    if [ ! -d "$M3SA_PY" ]; then
        echo "M3SA Python not found. Please include M3SA Python into ${M3SA_PY}"
        exit 1
    fi
    if [ ! -f "$M3SA_OPENDC_JAR" ]; then
        echo "M3SA JAR not found. Please run 'make build' first."
        exit 1
    fi
    if [ ! -d "$M3SA_PY/venv" ]; then
        echo "M3SA Python virtual environment not found. Please run 'make build' first."
        exit 1
    fi

    . "$M3SA_PY/venv/bin/activate"

    to_run=("figure4" "figure6" "experiment1" "experiment2" "experiment3")

    if [ ! -z "$1" ]; then
        to_run=("$1")
    fi

    echo "Running experiments: ${to_run[@]}"
    for experiment in "${to_run[@]}"; do
        if [ "$(type -t $experiment)" = function ]; then
            "$experiment" || exit 1
            export_figures || exit 1
        else
            echo "Experiment $experiment not found."
        fi
    done

    echo "Experiments complete."
}

figure4() {
    echo "Running figure 4..."
    java -jar "$M3SA_OPENDC_JAR" --experiment-path "$FIGURE_4_SCENARIO1" -m "${FIGURE_4_SETUP1}" -e "$M3SA_PY" || exit 1
    java -jar "$M3SA_OPENDC_JAR" --experiment-path "$FIGURE_4_SCENARIO2" -m "${FIGURE_4_SETUP2}" -e "$M3SA_PY" || exit 1
    java -jar "$M3SA_OPENDC_JAR" --experiment-path "$FIGURE_4_SCENARIO3" -m "${FIGURE_4_SETUP3}" -e "$M3SA_PY" || exit 1
    echo "Done figure 4."
}

figure6() {
    echo "Running figure 6..."
    java -jar "$M3SA_OPENDC_JAR" --experiment-path "$FIGURE_6_SCENARIO" -m "${FIGURE_6_SETUP1}" -e "$M3SA_PY" || exit 1
    java -jar "$M3SA_OPENDC_JAR" --experiment-path "$FIGURE_6_SCENARIO" -m "${FIGURE_6_SETUP20}" -e "$M3SA_PY" || exit 1
    java -jar "$M3SA_OPENDC_JAR" --experiment-path "$FIGURE_6_SCENARIO" -m "${FIGURE_6_SETUP100}" -e "$M3SA_PY" || exit 1
    echo "Done figure 6."
}

experiment1() {
    echo "Running experiment 1..."

    EXTRA_RAW_SIM="experiments/experiment1/footprinter/raw-output"

    # FIGURE A
    ./"$M3SA_PY/m3sa" -o "$EXP1_FOOTPRINTER_RESULT" "$EXP1_FOOTPRINTER_M3SA" "$EXP1_FOOTPRINTER_RAW" || exit 1

    # FIGURE B
    java -jar "$M3SA_OPENDC_JAR" --experiment-path "$EXP1_MULTIMODEL_SCENARIO" || exit 1
    for dir in $(ls "$EXTRA_RAW_SIM"); do
        mkdir -p "$EXP1_MULTIMODEL_RESULT/outputs/raw-output"
        cp -r "$EXTRA_RAW_SIM/$dir" "$EXP1_MULTIMODEL_RESULT/outputs/raw-output/$dir" || exit 1
    done
    ./"$M3SA_PY/m3sa" -o "$EXP1_MULTIMODEL_RESULT/outputs" "$EXP1_MULTIMODEL_M3SA" "$EXP1_MULTIMODEL_RESULT/outputs/raw-output" || exit 1

    # FIGURE C
    java -jar "$M3SA_OPENDC_JAR" --experiment-path "$EXP1_METAMODEL_SCENARIO" || exit 1
    for dir in $(ls "$EXTRA_RAW_SIM"); do
        mkdir -p "$EXP1_METAMODEL_RESULT/outputs/raw-output"
        cp -r "$EXTRA_RAW_SIM/$dir" "$EXP1_METAMODEL_RESULT/outputs/raw-output/$dir" || exit 1
    done
    ./"$M3SA_PY/m3sa" -o "$EXP1_METAMODEL_RESULT/outputs" "$EXP1_METAMODEL_M3SA" "$EXP1_METAMODEL_RESULT/outputs/raw-output" || exit 1

    echo "Done experiment 1."
}

experiment2() {
    echo "Running experiment 2..."
    for failure_model in "${EXP2_FAILURE_MODELS[@]}"; do
        for exp in "${EXP2_EXPERIMENTS[@]}"; do
            echo "Running experiment 2 for $exp with $failure_model..."
            java -jar "$M3SA_OPENDC_JAR" \
                --experiment-path "${EXP2_SCENARIO_PATH}/scenario-${exp}${failure_model}.json" \
                -m "${EXP2_M3SA_SETUP}/m3sa-${exp}${failure_model}.json" \
                -e "$M3SA_PY" || exit 1
        done
    done
    echo "Done experiment 2."
}

experiment3() {
    echo "Running experiment 3..."

    mkdir -p "$EXP3_METAMODELS_PATH" || exit 1
    cp -r "$EXP3_METAMODELS_COLLECTION"/* "$EXP3_METAMODELS_PATH" || exit 1
    python3 "$EXP3_PLOTTER_PATH" || exit 1

    echo "Experiment 3 done."
}

export_figures() {
    mkdir -p reproduced/
    for figure in $(find results -iname "*.pdf" -o -iname "*.png"); do
        local destination="reproduced/$(basename "$figure")"

        echo "Exporting $figure..."
        cp "$figure" "$destination" || exit 1
    done
}

main "$@"
